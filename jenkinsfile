pipeline {
    agent any

    stages {
        stage('Hello world testing') {
            agent {
                docker {
                    image 'node:18'
                }
            }
            steps {
                sh "echo 'Hello World'"
                sh 'npm install'
                sh 'npm --version'
            }
        }
        stage('AWS CLI test') {
            agent {
                docker {
                    image 'amazon/aws-cli'
                    arg "--entrypoint=''"
                }
            }
            steps {
                sh 'aws --version'

            }
        }
    }
}
