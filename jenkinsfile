pipeline {
    agent any

    stages {
        stage('Hello world testing') {
            agent {
                docker {
                    image 'node:18'
                    reuseNode true
                }
            }
            steps {
                sh "echo 'Hello World'"

            }
        }
        stage('AWS CLI test') {
            agent {
                docker {
                    image 'amazon/aws-cli'
                    args "--entrypoint=''"
                }
            }
            steps {
                sh 'aws --version'
                sh 'aws --version'

            }
        }
    }
    /*post {
        always {
            cleanWs()
        }
    }*/
}
